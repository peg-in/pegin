 configuration — copy to `.env` (gitignored) and fill in.
# No wallet-specific values are committed to the repo; supply yours here or via
# CI secrets/variables. Unit tests use a synthetic zero-entropy wallet and need none of these.

# ── Test / manual wallet (opt-in: smoke test, demo CLI) ───────────────────────
# A testnet wallet seed and its on-chain DID. Leave unset to skip the live checks.
# In CI: PEGIN_MNEMONIC = secret, PEGIN_DID = variable.
PEGIN_MNEMONIC=
PEGIN_DID=

# ── Chain data source (relay) ─────────────────────────────────────────────────
# coinset REST base used by the auth relay today (temporary; replaced by the
# lite wallet protocol in feat-54). Default: https://testnet11.api.coinset.org
PEGIN_COINSET_URL=
# Reserved for feat-54: the relay's lite-wallet peer (host:port, TLS).
PEGIN_PEER=

# ── Auth relay ────────────────────────────────────────────────────────────────
PEGIN_AUTH_PORT=8787
# HKDF salt embedded by pegin-jwt build.rs (CI: secret). Keep stable per deployment.
PEGIN_JWT_HKDF_SALT=

# ── Misc ──────────────────────────────────────────────────────────────────────
# error | warn | info | debug
LOG_LEVEL=error
