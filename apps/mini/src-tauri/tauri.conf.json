{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PEGIN Signer",
  "version": "0.1.0",
  "identifier": "app.pegin.signer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm vite --port 1420",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PEGIN Signer",
        "width": 460,
        "height": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["pegin-signer"]
      }
    }
  }
}
