{
  "name": "pegin-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build:wasm": "wasm-pack build crates/pegin-wasm --target bundler --out-dir ../../packages/sdk/wasm",
    "build": "pnpm build:wasm && cargo build --workspace && pnpm -r build",
    "test": "cargo test --workspace && pnpm -r test",
    "test:live": "cargo test --workspace -- --include-ignored",
    "dev": "pnpm -r dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings && pnpm -r lint",
    "format": "cargo fmt --all && pnpm exec prettier --write \"**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1"
  }
}
